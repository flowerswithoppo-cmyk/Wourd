<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Simple base theme for Compose host Activity -->
    <style name="Theme.Wourd" parent="Theme.Material.Light.NoActionBar" />

    <style name="Theme.Wourd.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/white</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.Wourd</item>
    </style>
</resources>

